@baseUrl = http://localhost:5353/api/v1

@authUrl = {{baseUrl}}/auth
@userUrl = {{baseUrl}}/users
@cartUrl = {{baseUrl}}/cart
@productUrl = {{baseUrl}}/public/products
@orderUrl = {{baseUrl}}/orders
@paymentUrl = {{baseUrl}}/payments
@adminOrderUrl = {{baseUrl}}/admin/orders
@adminPaymentUrl = {{baseUrl}}/admin/payments
@adminRefundUrl = {{baseUrl}}/admin/refunds
@adminSiteUrl = {{baseUrl}}/admin
@siteConfigUrl = {{baseUrl}}/public/site-config
@refundUrl = {{baseUrl}}/refunds
@analyticsUrl = {{baseUrl}}/admin/analytics

# --- AUTHENTICATION ---

### signin
POST {{authUrl}}/public/signin HTTP/1.1
Content-Type: application/json

{
    "email": "fatihb469@gmail.com"
}

### verify-login-otp
POST {{authUrl}}/public/signin-verify HTTP/1.1
Content-Type: application/json

{
  "email": "fatihb469@gmail.com",
  "code": "361577"
}

### refresh-token
POST {{authUrl}}/public/refresh-token HTTP/1.1

# --- USERS ---

### me
GET {{userUrl}}/me HTTP/1.1

### addresses
GET {{userUrl}}/addresses HTTP/1.1

# --- PRODUCTS ---

### get-products
GET {{productUrl}} HTTP/1.1

### list-products (search-query)
GET {{productUrl}}?query=iphone HTTP/1.1

@slug = urun-2-2c60d725

### get-product-by-slug
GET {{productUrl}}/slug/{{slug}} HTTP/1.1

### get-showcase-products
GET {{productUrl}}/showcase HTTP/1.1

### get-best-sellers
GET {{productUrl}}/best-sellers HTTP/1.1

# --- CART ---

### add-to-cart
POST {{cartUrl}}/items HTTP/1.1
Content-Type: application/json

{
  "variantId":"1fdf8b19-e637-449f-a97e-a5c2a7645024",
  "quantity": 1
}

### get-cart
GET {{cartUrl}} HTTP/1.1

@cartItemId = a05f6c8b-0fd5-4439-a40c-15b39727a097

### update-cart-item
PATCH {{cartUrl}}/items/{{cartItemId}} HTTP/1.1
Content-Type: application/json

{
  "quantity": 31
}

### remove-cart-item
DELETE {{cartUrl}}/items/{{cartItemId}} HTTP/1.1

# --- ORDER ---

### checkout-preview
POST {{orderUrl}}/checkout/preview HTTP/1.1
Content-Type: application/json

{
  "items": ["1fdf8b19-e637-449f-a97e-a5c2a7645024"]
}

### checkout
POST {{orderUrl}}/checkout HTTP/1.1
Content-Type: application/json

{
  "shippingAddressId" : "9f050d82-c9ac-4a44-964d-288792a9b350",
  "billingAddressId" : "9f050d82-c9ac-4a44-964d-288792a9b350",
  "items": ["1fdf8b19-e637-449f-a97e-a5c2a7645024"]
}

### get-orders
GET {{orderUrl}} HTTP/1.1

@orderId = 2a141ff1-6b1e-4096-a802-400904f74b0a

### get-order-by-id
GET {{orderUrl}}/{{orderId}} HTTP/1.1

### get-order-payment
GET {{orderUrl}}/{{orderId}}/payment HTTP/1.1

### cancel-order (sadece PENDING veya PREPARING siparişler)
POST {{orderUrl}}/{{orderId}}/cancel HTTP/1.1

### return-order (sadece DELIVERED siparişler)
POST {{orderUrl}}/{{orderId}}/return HTTP/1.1
Content-Type: application/json

{
  "reason": "Ürün beklentilerimi karşılamadı"
}

# --- PAYMENT ---

### create-payment-intent
POST {{paymentUrl}} HTTP/1.1
Content-Type: application/json

{
  "orderId": "2a141ff1-6b1e-4096-a802-400904f74b0a"
}

### get-payment-details
@paymentId = 44227b12-85d9-4309-8832-7c80af334b5a
GET {{paymentUrl}}/{{paymentId}} HTTP/1.1

# --- REFUNDS ---

### get-my-refunds
GET {{refundUrl}} HTTP/1.1

@refundId = 00000000-0000-0000-0000-000000000000

### get-my-refund-by-id
GET {{refundUrl}}/{{refundId}} HTTP/1.1

# --- ADMIN - ORDERS ---

### admin-get-all-orders
GET {{adminOrderUrl}} HTTP/1.1

### admin-get-all-orders (filtreli - RETURN_REQUESTED)
GET {{adminOrderUrl}}?status=RETURN_REQUESTED HTTP/1.1

### admin-get-order-by-id
GET {{adminOrderUrl}}/{{orderId}} HTTP/1.1

### admin-update-order-status
# Önce siparişi DELIVERED yaparak iade testine hazırla
PATCH {{adminOrderUrl}}/{{orderId}}/status HTTP/1.1
Content-Type: application/json

{
  "status": "DELIVERED"
}

### admin-ship-order
POST {{adminOrderUrl}}/{{orderId}}/ship HTTP/1.1
Content-Type: application/json

{
  "cargoFirm": "Yurtiçi Kargo",
  "trackingCode": "YK123456789TR"
}

### admin-approve-return
POST {{adminOrderUrl}}/{{orderId}}/return/approve HTTP/1.1

### admin-reject-return
POST {{adminOrderUrl}}/{{orderId}}/return/reject?reason=Ürün%20hasarlı%20gönderilemedi HTTP/1.1

# --- ADMIN - PAYMENTS ---

### admin-get-all-payments
GET {{adminPaymentUrl}} HTTP/1.1

### admin-get-payment-by-id
GET {{adminPaymentUrl}}/{{paymentId}} HTTP/1.1

### admin-capture-payment
POST {{adminPaymentUrl}}/{{paymentId}}/capture HTTP/1.1

### admin-void-payment
POST {{adminPaymentUrl}}/{{paymentId}}/void HTTP/1.1

# --- ADMIN - REFUNDS ---

### admin-get-all-refunds
GET {{adminRefundUrl}} HTTP/1.1

### admin-update-refund-status
PATCH {{adminRefundUrl}}/{{refundId}}/status HTTP/1.1
Content-Type: application/json

{
  "status": "SUCCEEDED"
}

# --- PUBLIC SITE CONFIG ---

### get-site-config
GET {{siteConfigUrl}} HTTP/1.1

# --- ADMIN - SITE CONFIG ---

### admin-upload-asset
POST {{adminSiteUrl}}/assets/upload HTTP/1.1
Content-Type: multipart/form-data; boundary=boundary

--boundary
Content-Disposition: form-data; name="file"; filename="logo.svg"
Content-Type: image/svg+xml

<svg>...</svg>
--boundary--

@uploadedAssetId = 00000000-0000-0000-0000-000000000000

### admin-update-site-setting
PATCH {{adminSiteUrl}}/site-settings/site_name HTTP/1.1
Content-Type: application/json

{
  "value": "My Awesome Shop"
}

### admin-update-site-asset-slot (logo)
PATCH {{adminSiteUrl}}/site-assets/logo HTTP/1.1
Content-Type: application/json

{
  "assetId": "{{uploadedAssetId}}"
}

# --- ANALYTICS ---

### analytics-dashboard
GET {{analyticsUrl}}/dashboard?from=2026-01-01T00:00:00Z&to=2026-12-31T23:59:59Z&tz=Europe/Istanbul HTTP/1.1

### analytics-orders
GET {{analyticsUrl}}/orders?from=2026-01-01T00:00:00Z&to=2026-12-31T23:59:59Z&tz=Europe/Istanbul HTTP/1.1

### analytics-payments
GET {{analyticsUrl}}/payments?from=2026-01-01T00:00:00Z&to=2026-12-31T23:59:59Z&tz=Europe/Istanbul HTTP/1.1

### analytics-products
GET {{analyticsUrl}}/products?from=2026-01-01T00:00:00Z&to=2026-12-31T23:59:59Z&tz=Europe/Istanbul HTTP/1.1

### analytics-users
GET {{analyticsUrl}}/users?from=2026-01-01T00:00:00Z&to=2026-12-31T23:59:59Z&tz=Europe/Istanbul HTTP/1.1

# --- AUDIT LOGS ---

### admin-audit-logs
GET {{baseUrl}}/admin/logs/audit HTTP/1.1

### admin-audit-logs-filtered-by-user
GET {{baseUrl}}/admin/logs/audit?entityType=ORDER&action=ORDER_STATUS_UPDATED HTTP/1.1

# --- WEBHOOKS ---

### stripe-webhook (gerçek Stripe-Signature üretmek için: stripe listen --forward-to localhost:5353/api/v1/webhooks/payments/stripe)
POST {{baseUrl}}/webhooks/payments/stripe HTTP/1.1
Content-Type: application/json
Stripe-Signature: t=1234567890,v1=abc123dummy

{
  "id": "evt_test_000000",
  "type": "checkout.session.completed",
  "data": {
    "object": {
      "id": "cs_test_SESSION_ID",
      "payment_status": "paid",
      "payment_intent": "pi_test_PAYMENT_INTENT_ID"
    }
  }
}

### iyzico-webhook
POST {{baseUrl}}/webhooks/payments/iyzico HTTP/1.1
Content-Type: application/x-www-form-urlencoded

token=TEST_IYZICO_TOKEN