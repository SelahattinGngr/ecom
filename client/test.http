@baseUrl = http://localhost:5353/api/v1

@authUrl = {{baseUrl}}/auth
@userUrl = {{baseUrl}}/users
@cartUrl = {{baseUrl}}/cart
@productUrl = {{baseUrl}}/public/products
@orderUrl = {{baseUrl}}/orders
@paymentUrl = {{baseUrl}}/payments
@adminOrderUrl = {{baseUrl}}/admin/orders
@adminPaymentUrl = {{baseUrl}}/admin/payments

# --- AUTHENTICATION ---

### signin
POST {{authUrl}}/public/signin HTTP/1.1
Content-Type: application/json

{
    "email": "fatihb469@gmail.com"
}

### verify-login-otp
POST {{authUrl}}/public/signin-verify HTTP/1.1
Content-Type: application/json

{
  "email": "fatihb469@gmail.com",
  "code": "361577"
}

### refresh-token
POST {{authUrl}}/public/refresh-token HTTP/1.1

# --- USERS ---

### me
GET {{userUrl}}/me HTTP/1.1

### addresses
GET {{userUrl}}/addresses HTTP/1.1

# --- PRODUCTS ---

### get-products
GET {{productUrl}} HTTP/1.1

### list-products (search-query)
GET {{productUrl}}?query=iphone HTTP/1.1

@slug = urun-2-2c60d725

### get-product-by-slug
GET {{productUrl}}/slug/{{slug}} HTTP/1.1

# --- CART ---

### add-to-cart
POST {{cartUrl}}/items HTTP/1.1
Content-Type: application/json

{
  "variantId":"1fdf8b19-e637-449f-a97e-a5c2a7645024",
  "quantity": 1
}

### get-cart
GET {{cartUrl}} HTTP/1.1

@cartItemId = a05f6c8b-0fd5-4439-a40c-15b39727a097

### update-cart-item
PATCH {{cartUrl}}/items/{{cartItemId}} HTTP/1.1
Content-Type: application/json

{
  "quantity": 31
}

### remove-cart-item
DELETE {{cartUrl}}/items/{{cartItemId}} HTTP/1.1

# --- ORDER ---

### checkout-preview
POST {{orderUrl}}/checkout/preview HTTP/1.1
Content-Type: application/json

{
  "items": ["1fdf8b19-e637-449f-a97e-a5c2a7645024"]
}

### checkout
POST {{orderUrl}}/checkout HTTP/1.1
Content-Type: application/json

{
  "shippingAddressId" : "9f050d82-c9ac-4a44-964d-288792a9b350",
  "billingAddressId" : "9f050d82-c9ac-4a44-964d-288792a9b350",
  "items": ["1fdf8b19-e637-449f-a97e-a5c2a7645024"]
}

### get-orders
GET {{orderUrl}} HTTP/1.1

@orderId = 2a141ff1-6b1e-4096-a802-400904f74b0a

### get-order-by-id
GET {{orderUrl}}/{{orderId}} HTTP/1.1

### cancel-order (sadece PENDING veya PREPARING siparişler)
POST {{orderUrl}}/{{orderId}}/cancel HTTP/1.1

### return-order (sadece DELIVERED siparişler)
POST {{orderUrl}}/{{orderId}}/return HTTP/1.1
Content-Type: application/json

{
  "reason": "Ürün beklentilerimi karşılamadı"
}

# --- PAYMENT ---

### create-payment-intent
POST {{paymentUrl}} HTTP/1.1
Content-Type: application/json

{
  "orderId": "2a141ff1-6b1e-4096-a802-400904f74b0a",
  "callbackUrl": "http://localhost:3000/payment-callback"
}

### get-payment-details
@paymentId = 44227b12-85d9-4309-8832-7c80af334b5a
GET {{paymentUrl}}/{{paymentId}} HTTP/1.1

# --- ADMIN - ORDERS ---

### admin-get-all-orders
GET {{adminOrderUrl}} HTTP/1.1

### admin-get-all-orders (filtreli - RETURN_REQUESTED)
GET {{adminOrderUrl}}?status=RETURN_REQUESTED HTTP/1.1

### admin-get-order-by-id
GET {{adminOrderUrl}}/{{orderId}} HTTP/1.1

### admin-update-order-status
# Önce siparişi DELIVERED yaparak iade testine hazırla
PATCH {{adminOrderUrl}}/{{orderId}}/status HTTP/1.1
Content-Type: application/json

{
  "status": "DELIVERED"
}

### admin-ship-order
POST {{adminOrderUrl}}/{{orderId}}/ship HTTP/1.1
Content-Type: application/json

{
  "cargoFirm": "Yurtiçi Kargo",
  "trackingCode": "YK123456789TR"
}

### admin-approve-return
POST {{adminOrderUrl}}/{{orderId}}/return/approve HTTP/1.1

### admin-reject-return
POST {{adminOrderUrl}}/{{orderId}}/return/reject?reason=Ürün%20hasarlı%20gönderilemedi HTTP/1.1

# --- ADMIN - PAYMENTS ---

### admin-get-all-payments
GET {{adminPaymentUrl}} HTTP/1.1

### admin-get-payment-by-id
GET {{adminPaymentUrl}}/{{paymentId}} HTTP/1.1

### admin-capture-payment
POST {{adminPaymentUrl}}/{{paymentId}}/capture HTTP/1.1

### admin-void-payment
POST {{adminPaymentUrl}}/{{paymentId}}/void HTTP/1.1